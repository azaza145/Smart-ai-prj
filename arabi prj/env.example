# SmartRecruit Environment - copy to .env
APP_ENV=development
APP_DEBUG=1
APP_URL=http://localhost:8080

DB_HOST=mysql
DB_PORT=3306
DB_NAME=smartrecruit
DB_USER=smartrecruit
DB_PASS=smartrecruit_secret

CSV_DATASET_PATH=/var/www/html/dataset_cvs_5000.csv
PYTHON_PATH=python3

MAX_CV_SIZE_MB=5
MAX_CV_MIME=application/pdf

# AI/NLP step for CV parsing (Ollama) — désactivé par défaut (plus rapide, résultat rule-based uniquement)
# Mettre CV_AI_ENABLED=1 pour activer ; peut être lent et le résultat varie.
# CV_AI_ENABLED=0
# CV_LLM_API_URL=http://host.docker.internal:11434/v1
# CV_LLM_API_KEY=
# CV_LLM_MODEL=llama3.2

# Ollama CV extraction (local) — profil structuré unique pour aperçu + PDF
# OLLAMA_CV_ENABLED=1 pour utiliser Ollama pour le pré-remplissage depuis le CV
# OLLAMA_CV_ENABLED=0
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_TIMEOUT=90
# OLLAMA_CV_MODEL=qwen2.5:7b
# OLLAMA_CV_FALLBACK_MODEL=llama3.2:3b
